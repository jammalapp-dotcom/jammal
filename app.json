{
  "expo": {
    "name": "جمّال - Jammal",
    "slug": "jammal",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/jammal_logo_mini.png",
    "scheme": "jammal",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.jammal.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/jammal_logo_mini.png",
        "backgroundColor": "#1B2A4A"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.jammal.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/jammal-logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#1B2A4A"
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1083dc1c-c366-440c-82a4-b20d1c39b0dd"
      }
    }
  }
}