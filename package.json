{
  "name": "jammal-monorepo",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "dev:turbo": "turbo run dev",
    "dev:web": "turbo run dev --filter=@jammal/web",
    "dev:mobile": "turbo run dev --filter=@jammal/mobile",
    "build:turbo": "turbo run build",
    "build:web": "turbo run build --filter=@jammal/web",
    "type-check": "turbo run type-check",
    "db:migrate": "cd packages/db && pnpm run migrate",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "dependencies": {
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "next-themes": "^0.4.4",
    "lucide-react": "^0.468.0",
    "recharts": "^2.15.0",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.6.0",
    "class-variance-authority": "^0.7.1"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "~5.8.3",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "postcss": "^8.4.49",
    "autoprefixer": "^10.4.20"
  }
}
