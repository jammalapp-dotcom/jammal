{
  "name": "jammal-monorepo",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@jammal/web",
    "dev:mobile": "turbo run dev --filter=@jammal/mobile",
    "build": "turbo run build",
    "build:web": "turbo run build --filter=@jammal/web",
    "type-check": "turbo run type-check",
    "lint": "turbo run lint",
    "db:migrate": "cd packages/db && pnpm run migrate",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "~5.8.3"
  }
}
