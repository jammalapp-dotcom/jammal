{
    "expo": {
        "name": "Jammal",
        "slug": "jammal",
        "version": "1.0.0",
        "scheme": "jammal",
        "platforms": [
            "ios",
            "android"
        ],
        "orientation": "portrait",
        "icon": "./assets/icon.png",
        "splash": {
            "image": "./assets/splash.png",
            "resizeMode": "contain",
            "backgroundColor": "#1B365D"
        },
        "ios": {
            "supportsTablet": false,
            "bundleIdentifier": "sa.jammal.app",
            "infoPlist": {
                "NSLocationAlwaysAndWhenInUseUsageDescription": "Jammal needs access to your location for real-time shipment tracking.",
                "NSLocationWhenInUseUsageDescription": "Jammal needs access to your location to show nearby shipments.",
                "NSCameraUsageDescription": "Jammal needs camera access to take photos of cargo and documents."
            }
        },
        "android": {
            "package": "sa.jammal.app",
            "adaptiveIcon": {
                "foregroundImage": "./assets/adaptive-icon.png",
                "backgroundColor": "#1B365D"
            },
            "permissions": [
                "ACCESS_FINE_LOCATION",
                "ACCESS_COARSE_LOCATION",
                "ACCESS_BACKGROUND_LOCATION",
                "CAMERA"
            ]
        },
        "plugins": [
            "expo-router",
            "expo-location",
            "expo-secure-store",
            "expo-image-picker",
            "expo-notifications"
        ],
        "extra": {
            "eas": {
                "projectId": "your-eas-project-id"
            }
        },
        "locales": {
            "ar": "./locales/ar.json",
            "en": "./locales/en.json"
        }
    }
}