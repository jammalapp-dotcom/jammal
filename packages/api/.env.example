# ============================================================================
# JAMMAL — API Server Environment Variables
# Copy this file to .env and fill in your values
# ============================================================================

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/jammal

# JWT Authentication
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# OTP Settings
OTP_EXPIRY_MINUTES=5
OTP_RESEND_SECONDS=30

# Unifonic SMS Gateway (Saudi Arabia)
UNIFONIC_APP_SID=your_unifonic_app_sid
UNIFONIC_SENDER_ID=Jammal

# Google Maps API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Web App URL (for CORS)
WEB_URL=http://localhost:3000

# Server Port
PORT=3001
