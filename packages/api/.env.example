# Jammal API Environment Variables
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/jammal

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=7d
JWT_REFRESH_EXPIRATION=30d

# OTP
OTP_EXPIRY_MINUTES=2
OTP_RESEND_SECONDS=30

# Google Maps API
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# SMS Provider (Unifonic / Twilio)
SMS_PROVIDER=unifonic
UNIFONIC_APP_SID=your-unifonic-app-sid
UNIFONIC_SENDER_ID=JAMMAL
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+966xxxxxxxxx

# Payment Gateway (Hyperpay / Moyasar)
PAYMENT_GATEWAY=moyasar
MOYASAR_API_KEY=your-moyasar-api-key
MOYASAR_PUBLISHABLE_KEY=your-moyasar-publishable-key
HYPERPAY_ACCESS_TOKEN=your-hyperpay-access-token
HYPERPAY_ENTITY_ID=your-hyperpay-entity-id

# AWS S3
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=me-south-1
AWS_S3_BUCKET=jammal-uploads

# Redis
REDIS_URL=redis://localhost:6379

# SendGrid
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@jammal.sa

# Firebase (FCM)
FIREBASE_PROJECT_ID=jammal-freight
FIREBASE_PRIVATE_KEY=your-firebase-private-key
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@jammal-freight.iam.gserviceaccount.com
