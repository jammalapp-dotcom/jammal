// ============================================================================
// JAMMAL FREIGHT PLATFORM — PRISMA SCHEMA
// Complete database schema per Section 16 of the Technical Requirements
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

enum UserType {
  customer
  driver
  broker
  admin
  support
}

enum Gender {
  male
  female
}

enum UserStatus {
  active
  suspended
  banned
}

enum VerificationStatus {
  pending
  approved
  rejected
}

enum VehicleType {
  pickup
  small_lorry
  medium_lorry
  large_truck
  refrigerated
  flatbed
  tanker
  car_carrier
  crane_truck
}

enum ShipmentStatus {
  draft
  searching
  driver_assigned
  driver_en_route_pickup
  arrived_pickup
  cargo_loaded
  in_transit
  arrived_delivery
  delivered
  cancelled
  disputed
}

enum PricingType {
  instant_quote
  bidding
}

enum BidStatus {
  pending
  accepted
  rejected
  withdrawn
  expired
}

enum PaymentType {
  shipment
  refund
  payout
  commission
}

enum PaymentMethod {
  card
  mada
  apple_pay
  stc_pay
  bank_transfer
  cash
  wallet
}

enum PaymentStatus {
  pending
  authorized
  captured
  failed
  refunded
}

enum MessageType {
  text
  image
  location
  system
}

enum NotificationType {
  shipment_update
  bid_received
  bid_accepted
  bid_rejected
  payment_received
  payment_failed
  driver_assigned
  delivery_completed
  rating_reminder
  document_expiry
  system_alert
  promotional
}

enum CargoHandling {
  fragile
  refrigerated
  hazardous
  heavy_machinery
  oversized
  valuable
  perishable
  liquid
}

// ============================================================================
// CORE TABLES
// ============================================================================

/// Users — central auth table for all roles (Section 3.1)
model User {
  id              String     @id @default(uuid()) @db.Uuid
  userType        UserType   @map("user_type")
  fullNameEn      String     @map("full_name_en") @db.VarChar(100)
  fullNameAr      String     @map("full_name_ar") @db.VarChar(100)
  email           String     @unique @db.VarChar(100)
  emailVerified   Boolean    @default(false) @map("email_verified")
  phone           String     @unique @db.VarChar(20)
  phoneVerified   Boolean    @default(false) @map("phone_verified")
  passwordHash    String     @map("password_hash") @db.VarChar(255)
  profilePhotoUrl String?    @map("profile_photo_url") @db.VarChar(500)
  nationalId      String?    @map("national_id") @db.VarChar(20)
  dateOfBirth     DateTime?  @map("date_of_birth") @db.Date
  gender          Gender?
  status          UserStatus @default(active)
  locale          String     @default("ar") @db.VarChar(5)
  fcmToken        String?    @map("fcm_token") @db.VarChar(500)
  lastLoginAt     DateTime?  @map("last_login_at")
  failedLoginAttempts Int    @default(0) @map("failed_login_attempts")
  lockedUntil     DateTime?  @map("locked_until")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  // Relations
  customerProfile CustomerProfile?
  driverProfile   DriverProfile?
  brokerProfile   BrokerProfile?
  vehicles        Vehicle[]
  shipmentsAsCustomer Shipment[] @relation("ShipmentCustomer")
  shipmentsAsBroker   Shipment[] @relation("ShipmentBroker")
  shipmentsAsDriver   Shipment[] @relation("ShipmentDriver")
  bids                Bid[]
  paymentsInitiated   Payment[] @relation("PaymentUser")
  ratingsGiven        Rating[]  @relation("RatingBy")
  ratingsReceived     Rating[]  @relation("RatingFor")
  messagesSent        Message[] @relation("MessageSender")
  messagesReceived    Message[] @relation("MessageReceiver")
  notifications       Notification[]
  locationHistory     LocationHistory[]
  otpCodes            OtpCode[]
  refreshTokens       RefreshToken[]
  savedAddresses      SavedAddress[]
  brokerDrivers       BrokerDriver[] @relation("BrokerUser")
  driverOfBrokers     BrokerDriver[] @relation("DriverUser")

  @@map("users")
}

/// Customer-specific profile data (Section 4)
model CustomerProfile {
  userId                String   @id @map("user_id") @db.Uuid
  companyName           String?  @map("company_name") @db.VarChar(100)
  companyCr             String?  @map("company_cr") @db.VarChar(20)
  isBusiness            Boolean  @default(false) @map("is_business")
  preferredPaymentMethod String? @map("preferred_payment_method") @db.VarChar(50)
  totalShipments        Int      @default(0) @map("total_shipments")
  totalSpent            Decimal  @default(0) @map("total_spent") @db.Decimal(12, 2)
  averageRating         Decimal? @map("average_rating") @db.Decimal(3, 2)
  createdAt             DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("customer_profiles")
}

/// Driver-specific profile data with verification and location (Section 5)
model DriverProfile {
  userId              String             @id @map("user_id") @db.Uuid
  verificationStatus  VerificationStatus @default(pending) @map("verification_status")
  driverLicenseNumber String?            @map("driver_license_number") @db.VarChar(50)
  driverLicenseExpiry DateTime?          @map("driver_license_expiry") @db.Date
  driverLicensePhotoUrl String?          @map("driver_license_photo_url") @db.VarChar(500)
  nationalIdPhotoFront  String?          @map("national_id_photo_front") @db.VarChar(500)
  nationalIdPhotoBack   String?          @map("national_id_photo_back") @db.VarChar(500)
  isOnline              Boolean          @default(false) @map("is_online")
  currentLatitude       Decimal?         @map("current_latitude") @db.Decimal(10, 8)
  currentLongitude      Decimal?         @map("current_longitude") @db.Decimal(11, 8)
  lastLocationUpdate    DateTime?        @map("last_location_update")
  totalTrips            Int              @default(0) @map("total_trips")
  totalEarnings         Decimal          @default(0) @map("total_earnings") @db.Decimal(12, 2)
  availableBalance      Decimal          @default(0) @map("available_balance") @db.Decimal(12, 2)
  averageRating         Decimal?         @map("average_rating") @db.Decimal(3, 2)
  acceptanceRate        Decimal?         @map("acceptance_rate") @db.Decimal(5, 2)
  cancellationRate      Decimal?         @map("cancellation_rate") @db.Decimal(5, 2)
  onTimeRate            Decimal?         @map("on_time_rate") @db.Decimal(5, 2)
  iban                  String?          @db.VarChar(34)
  serviceAreas          Json?            @map("service_areas")
  maxDistance           Int?              @map("max_distance") // km
  createdAt             DateTime         @default(now()) @map("created_at")
  updatedAt             DateTime         @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([isOnline, currentLatitude, currentLongitude], map: "idx_drivers_online_location")
  @@map("driver_profiles")
}

/// Broker/Company-specific profile data (Section 6)
model BrokerProfile {
  userId                 String             @id @map("user_id") @db.Uuid
  companyNameEn          String?            @map("company_name_en") @db.VarChar(100)
  companyNameAr          String?            @map("company_name_ar") @db.VarChar(100)
  commercialRegistration String?            @map("commercial_registration") @db.VarChar(50)
  crPhotoUrl             String?            @map("cr_photo_url") @db.VarChar(500)
  taxNumber              String?            @map("tax_number") @db.VarChar(50)
  licenseNumber          String?            @map("license_number") @db.VarChar(50)
  verificationStatus     VerificationStatus @default(pending) @map("verification_status")
  totalShipments         Int                @default(0) @map("total_shipments")
  totalRevenue           Decimal            @default(0) @map("total_revenue") @db.Decimal(12, 2)
  commissionRate         Decimal            @default(10.00) @map("commission_rate") @db.Decimal(5, 2)
  iban                   String?            @db.VarChar(34)
  createdAt              DateTime           @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("broker_profiles")
}

/// Vehicles belonging to drivers (Section 3.2)
model Vehicle {
  id                  String      @id @default(uuid()) @db.Uuid
  driverId            String      @map("driver_id") @db.Uuid
  vehicleType         VehicleType @map("vehicle_type")
  make                String?     @db.VarChar(50)
  model               String?     @db.VarChar(50)
  year                Int?
  licensePlate        String      @unique @map("license_plate") @db.VarChar(20)
  color               String?     @db.VarChar(30)
  capacityKg          Decimal     @map("capacity_kg") @db.Decimal(8, 2)
  lengthMeters        Decimal?    @map("length_meters") @db.Decimal(5, 2)
  registrationNumber  String?     @map("registration_number") @db.VarChar(50)
  registrationExpiry  DateTime?   @map("registration_expiry") @db.Date
  registrationPhotoUrl String?    @map("registration_photo_url") @db.VarChar(500)
  insuranceNumber     String?     @map("insurance_number") @db.VarChar(50)
  insuranceExpiry     DateTime?   @map("insurance_expiry") @db.Date
  insurancePhotoUrl   String?     @map("insurance_photo_url") @db.VarChar(500)
  vehiclePhotos       Json?       @map("vehicle_photos") // Array of photo URLs
  isActive            Boolean     @default(true) @map("is_active")
  createdAt           DateTime    @default(now()) @map("created_at")
  updatedAt           DateTime    @updatedAt @map("updated_at")

  driver User @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@map("vehicles")
}

/// Shipments — the core transactional entity (Section 4.2)
model Shipment {
  id                  String         @id @default(uuid()) @db.Uuid
  customerId          String         @map("customer_id") @db.Uuid
  brokerId            String?        @map("broker_id") @db.Uuid
  driverId            String?        @map("driver_id") @db.Uuid

  // Pickup details
  pickupAddress       String         @map("pickup_address")
  pickupLatitude      Decimal        @map("pickup_latitude") @db.Decimal(10, 8)
  pickupLongitude     Decimal        @map("pickup_longitude") @db.Decimal(11, 8)
  pickupContactName   String?        @map("pickup_contact_name") @db.VarChar(100)
  pickupContactPhone  String?        @map("pickup_contact_phone") @db.VarChar(20)
  pickupDate          DateTime?      @map("pickup_date") @db.Date
  pickupTime          DateTime?      @map("pickup_time") @db.Time()
  pickupInstructions  String?        @map("pickup_instructions")

  // Delivery details
  deliveryAddress     String         @map("delivery_address")
  deliveryLatitude    Decimal        @map("delivery_latitude") @db.Decimal(10, 8)
  deliveryLongitude   Decimal        @map("delivery_longitude") @db.Decimal(11, 8)
  deliveryContactName String?        @map("delivery_contact_name") @db.VarChar(100)
  deliveryContactPhone String?       @map("delivery_contact_phone") @db.VarChar(20)
  deliveryDate        DateTime?      @map("delivery_date") @db.Date
  deliveryTime        DateTime?      @map("delivery_time") @db.Time()
  deliveryInstructions String?       @map("delivery_instructions")

  // Cargo details
  cargoType           String?        @map("cargo_type") @db.VarChar(100)
  cargoDescription    String?        @map("cargo_description")
  cargoWeightKg       Decimal?       @map("cargo_weight_kg") @db.Decimal(8, 2)
  cargoLengthCm       Decimal?       @map("cargo_length_cm") @db.Decimal(6, 2)
  cargoWidthCm        Decimal?       @map("cargo_width_cm") @db.Decimal(6, 2)
  cargoHeightCm       Decimal?       @map("cargo_height_cm") @db.Decimal(6, 2)
  cargoQuantity       Int?           @map("cargo_quantity")
  cargoPhotos         Json?          @map("cargo_photos")
  specialHandling     Json?          @map("special_handling") // CargoHandling[]

  // Vehicle requirements
  requiredVehicleType String?        @map("required_vehicle_type") @db.VarChar(50)
  minimumCapacityKg   Decimal?       @map("minimum_capacity_kg") @db.Decimal(8, 2)

  // Pricing
  pricingType         PricingType    @map("pricing_type")
  estimatedPrice      Decimal?       @map("estimated_price") @db.Decimal(10, 2)
  finalPrice          Decimal?       @map("final_price") @db.Decimal(10, 2)
  platformCommission  Decimal?       @map("platform_commission") @db.Decimal(10, 2)
  insuranceFee        Decimal?       @map("insurance_fee") @db.Decimal(10, 2)
  insuranceValue      Decimal?       @map("insurance_value") @db.Decimal(10, 2)
  maxAcceptablePrice  Decimal?       @map("max_acceptable_price") @db.Decimal(10, 2)

  // Status
  status              ShipmentStatus @default(draft)

  // Timestamps
  assignedAt          DateTime?      @map("assigned_at")
  pickupCompletedAt   DateTime?      @map("pickup_completed_at")
  deliveryCompletedAt DateTime?      @map("delivery_completed_at")
  cancelledAt         DateTime?      @map("cancelled_at")
  biddingExpiresAt    DateTime?      @map("bidding_expires_at")

  // Proof
  pickupProofPhotoUrl   String?      @map("pickup_proof_photo_url") @db.VarChar(500)
  deliveryProofPhotoUrl String?      @map("delivery_proof_photo_url") @db.VarChar(500)
  customerSignature     String?      @map("customer_signature") // Base64
  
  distanceKm          Decimal?       @map("distance_km") @db.Decimal(8, 2)
  durationMinutes     Int?           @map("duration_minutes")

  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")

  // Relations
  customer    User       @relation("ShipmentCustomer", fields: [customerId], references: [id])
  broker      User?      @relation("ShipmentBroker", fields: [brokerId], references: [id])
  driver      User?      @relation("ShipmentDriver", fields: [driverId], references: [id])
  bids        Bid[]
  payments    Payment[]
  ratings     Rating[]
  messages    Message[]
  locationHistory LocationHistory[]

  @@index([customerId, status], map: "idx_shipments_customer_status")
  @@index([driverId, status], map: "idx_shipments_driver_status")
  @@index([status, createdAt], map: "idx_shipments_status_created")
  @@map("shipments")
}

/// Bids from drivers on bidding-type shipments (Section 4.3)
model Bid {
  id          String    @id @default(uuid()) @db.Uuid
  shipmentId  String    @map("shipment_id") @db.Uuid
  driverId    String    @map("driver_id") @db.Uuid
  bidAmount   Decimal   @map("bid_amount") @db.Decimal(10, 2)
  message     String?
  status      BidStatus @default(pending)
  createdAt   DateTime  @default(now()) @map("created_at")
  expiresAt   DateTime? @map("expires_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  driver   User     @relation(fields: [driverId], references: [id])

  @@unique([shipmentId, driverId])
  @@map("bids")
}

/// Payments — all financial transactions (Section 7)
model Payment {
  id             String        @id @default(uuid()) @db.Uuid
  shipmentId     String?       @map("shipment_id") @db.Uuid
  userId         String        @map("user_id") @db.Uuid
  paymentType    PaymentType   @map("payment_type")
  amount         Decimal       @db.Decimal(10, 2)
  currency       String        @default("SAR") @db.VarChar(3)
  paymentMethod  PaymentMethod @map("payment_method")
  paymentGateway String?       @map("payment_gateway") @db.VarChar(50)
  transactionId  String?       @map("transaction_id") @db.VarChar(100)
  status         PaymentStatus @default(pending)
  metadata       Json?
  createdAt      DateTime      @default(now()) @map("created_at")
  completedAt    DateTime?     @map("completed_at")

  shipment Shipment? @relation(fields: [shipmentId], references: [id])
  user     User      @relation("PaymentUser", fields: [userId], references: [id])

  @@index([userId, paymentType], map: "idx_payments_user_type")
  @@map("payments")
}

/// Ratings — multi-dimensional review system (Section 10)
model Rating {
  id                       String   @id @default(uuid()) @db.Uuid
  shipmentId               String   @map("shipment_id") @db.Uuid
  ratedBy                  String   @map("rated_by") @db.Uuid
  ratedUser                String   @map("rated_user") @db.Uuid
  overallRating            Int      @map("overall_rating") // 1-5
  punctualityRating        Int?     @map("punctuality_rating")
  professionalismRating    Int?     @map("professionalism_rating")
  vehicleCleanlinessRating Int?     @map("vehicle_cleanliness_rating")
  cargoHandlingRating      Int?     @map("cargo_handling_rating")
  reviewText               String?  @map("review_text")
  reviewPhotos             Json?    @map("review_photos")
  tags                     Json?    // Array of tags
  isPublished              Boolean  @default(false) @map("is_published")
  createdAt                DateTime @default(now()) @map("created_at")

  shipment  Shipment @relation(fields: [shipmentId], references: [id])
  reviewer  User     @relation("RatingBy", fields: [ratedBy], references: [id])
  ratedFor  User     @relation("RatingFor", fields: [ratedUser], references: [id])

  @@unique([shipmentId, ratedBy])
  @@map("ratings")
}

/// Messages — in-app chat system (Section 11)
model Message {
  id             String      @id @default(uuid()) @db.Uuid
  conversationId String      @map("conversation_id") @db.Uuid
  senderId       String      @map("sender_id") @db.Uuid
  receiverId     String      @map("receiver_id") @db.Uuid
  shipmentId     String?     @map("shipment_id") @db.Uuid
  messageType    MessageType @default(text) @map("message_type")
  messageText    String?     @map("message_text")
  mediaUrl       String?     @map("media_url") @db.VarChar(500)
  latitude       Decimal?    @db.Decimal(10, 8)
  longitude      Decimal?    @db.Decimal(11, 8)
  isRead         Boolean     @default(false) @map("is_read")
  createdAt      DateTime    @default(now()) @map("created_at")

  sender   User      @relation("MessageSender", fields: [senderId], references: [id])
  receiver User      @relation("MessageReceiver", fields: [receiverId], references: [id])
  shipment Shipment? @relation(fields: [shipmentId], references: [id])

  @@index([conversationId, createdAt])
  @@map("messages")
}

/// LocationHistory — GPS tracking data (Section 8), high-volume time-series
model LocationHistory {
  id         BigInt   @id @default(autoincrement())
  shipmentId String   @map("shipment_id") @db.Uuid
  driverId   String   @map("driver_id") @db.Uuid
  latitude   Decimal  @db.Decimal(10, 8)
  longitude  Decimal  @db.Decimal(11, 8)
  heading    Decimal? @db.Decimal(5, 2)
  speedKmh   Decimal? @map("speed_kmh") @db.Decimal(5, 2)
  timestamp  DateTime @default(now())

  shipment Shipment @relation(fields: [shipmentId], references: [id])
  driver   User     @relation(fields: [driverId], references: [id])

  @@index([shipmentId, timestamp], map: "idx_location_history_shipment_time")
  @@map("location_history")
}

/// Notifications — push/SMS/email (Section 9)
model Notification {
  id               String           @id @default(uuid()) @db.Uuid
  userId           String           @map("user_id") @db.Uuid
  notificationType NotificationType @map("notification_type")
  title            String           @db.VarChar(200)
  titleAr          String?          @map("title_ar") @db.VarChar(200)
  message          String
  messageAr        String?          @map("message_ar")
  data             Json?            // Additional data (shipment_id, etc.)
  isRead           Boolean          @default(false) @map("is_read")
  sentPush         Boolean          @default(false) @map("sent_push")
  sentSms          Boolean          @default(false) @map("sent_sms")
  sentEmail        Boolean          @default(false) @map("sent_email")
  createdAt        DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead], map: "idx_notifications_user_read")
  @@map("notifications")
}

// ============================================================================
// SUPPLEMENTARY TABLES
// ============================================================================

/// OTP codes for phone/email verification (Section 3.1)
model OtpCode {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  code      String   @db.VarChar(6)
  purpose   String   @db.VarChar(30) // 'registration', 'login', 'password_reset'
  expiresAt DateTime @map("expires_at")
  verified  Boolean  @default(false)
  attempts  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("otp_codes")
}

/// Refresh tokens for JWT auth (Section 3.4)
model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  token     String   @unique @db.VarChar(500)
  device    String?  @db.VarChar(200)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

/// Saved addresses for quick shipment creation
model SavedAddress {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  label     String   @db.VarChar(50) // "Home", "Office", "Warehouse"
  address   String
  latitude  Decimal  @db.Decimal(10, 8)
  longitude Decimal  @db.Decimal(11, 8)
  contactName  String? @map("contact_name") @db.VarChar(100)
  contactPhone String? @map("contact_phone") @db.VarChar(20)
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("saved_addresses")
}

/// Broker-Driver relationships (Section 6.3)
model BrokerDriver {
  id              String   @id @default(uuid()) @db.Uuid
  brokerId        String   @map("broker_id") @db.Uuid
  driverId        String   @map("driver_id") @db.Uuid
  commissionSplit Decimal  @default(70.00) @map("commission_split") @db.Decimal(5, 2) // Driver's %
  status          String   @default("active") @db.VarChar(20)
  assignedRoutes  Json?    @map("assigned_routes")
  createdAt       DateTime @default(now()) @map("created_at")

  broker User @relation("BrokerUser", fields: [brokerId], references: [id])
  driver User @relation("DriverUser", fields: [driverId], references: [id])

  @@unique([brokerId, driverId])
  @@map("broker_drivers")
}
